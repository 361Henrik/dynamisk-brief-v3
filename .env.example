# Supabase
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# App config
# Custom domain: brief.gs1.threesix1.com
# NOTE: Verify domain spelling with Henrik before DNS config — may be threesixty1.com
VITE_APP_URL=https://brief.gs1.threesix1.com

# Optional: email for feedback notifications
FEEDBACK_EMAIL=henrik@threesixty1.com
